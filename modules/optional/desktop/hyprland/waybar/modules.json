  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "َ°‚„  {capacity}%",
    "format-plugged": "َ°‚„  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚‚", "َ±ں¢"],
    "on-click": "powerprofilesctl set performance && notify-send -u low \"Switch to $(powerprofilesctl get)\"",
    "on-click-right": "powerprofilesctl set power-saver && notify-send -u low \"Switch to $(powerprofilesctl get)\""
  },
  "clock": {
