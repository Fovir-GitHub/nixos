{
  "custom/nixos": {
    "format": "пЊ“",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "sway/window": {
    "format": "{app_id}",
    "icon": true,
    "icon-size": 16
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "warp-on-scroll": true,
    "on-scroll-up": "swaymsg workspace prev",
    "on-scroll-down": "swaymsg workspace next",
    "format": "{name}",
    "format-icons": {
      "urgent": "пЃЄ",
      "active": "п†’",
      "default": "п„‘"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}  {text}",
    "format-icons": {
      "notification": "у°‚љ",
      "none": "у°‚њ",
      "dnd-notification": "у°‚›",
      "dnd-none": "у°‚›"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "wireplumber": {
    "on-click": "pwvucontrol",
    "on-click-right": "swayosd-client --output-volume mute-toggle",
    "on-scroll-down": "swayosd-client --output-volume -1",
    "on-scroll-up": "swayosd-client --output-volume +1",
    "format": "{icon} {volume}%",
    "format-muted": "у°ќџ 0%",
    "format-source": "п„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    }
  },
  "cpu": {
    "format": "п‹›  {usage}%",
    "tooltip": true,
    "interval": 1
  },
  "memory": {
    "format": "ої…  {used} / {total} GiB",
    "tooltip": true,
    "interval": 1
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "п‹‡ {temperatureC}",
    "format": "п‹‰ {temperatureC}В°C"
  },
  "network": {
    "format": "оЄЎ {bandwidthTotalBytes} оЄљ {bandwidthDownBytes}",
    "interval": 1
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "у°‚„  {capacity}%",
    "format-plugged": "у°‚„  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚‚", "у±џў"],
    "on-click": "powerprofilesctl set performance && notify-send -u low \"Switch to $(powerprofilesctl get)\"",
    "on-click-right": "powerprofilesctl set power-saver && notify-send -u low \"Switch to $(powerprofilesctl get)\""
  },
  "clock": {
    "format": "пЃі {:%a %b %d %H:%M:%S %Z}",
    "interval": 1,
    "timezones": ["Singapore", "UTC"],
    "actions": {
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down"
    }
  }
}
