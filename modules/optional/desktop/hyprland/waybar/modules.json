      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    },
    "on-click": "pavucontrol"
  },
  "cpu": {
    "format": "´ïø  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "¯┐à  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "´ïç {temperatureC}",
    "format": "´ïë {temperatureC}┬░C"
  },
  "backlight": {
