{
  "custom/nixos": {
    "format": "ΎΝΥ",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "hyprland/window": {
    "format": "{initialTitle}",
    "icon": true
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "warp-on-scroll": true,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{name}",
    "format-icons": {
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}  {text}",
    "format-icons": {
      "notification": "≤░Γγ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γδ",
      "dnd-none": "≤░Γδ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "wireplumber": {
    "on-click": "pwvucontrol",
    "on-click-right": "swayosd-client --output-volume mute-toggle",
    "on-scroll-down": "swayosd-client --output-volume -1",
    "on-scroll-up": "swayosd-client --output-volume +1",
    "format": "{icon} {volume}%",
    "format-muted": "≤░ζθ",
    "format-source": "ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    }
  },
  "cpu": {
    "format": "ΎΜδ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "Ό┐Ζ  {used} / {total} GiB",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "ΎΜΘ {temperatureC}",
    "format": "ΎΜΚ {temperatureC}┬░C"
  },
  "network": {
    "format": "Όςκ {bandwidthTotalBytes} Όςγ {bandwidthDownBytes}",
    "interval": 1
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "≤░ΓΕ  {capacity}%",
    "format-plugged": "≤░ΓΕ  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΓ", "≤▒θλ"],
    "on-click": "powerprofilesctl set performance && notify-send -u low \"Switch to $(powerprofilesctl get)\"",
    "on-click-right": "powerprofilesctl set power-saver && notify-send -u low \"Switch to $(powerprofilesctl get)\""
  },
  "clock": {
    "format": "ΎΒ│ {:%a %b %d %H:%M:%S}",
    "interval": 1
  }
}
