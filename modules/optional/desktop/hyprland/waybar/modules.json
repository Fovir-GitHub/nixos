{
  "custom/nixos": {
    "format": "ïŒ“",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "hyprland/window": {
    "format": "{initialTitle}",
    "icon": true,
    "icon-size": 16
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "warp-on-scroll": true,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{name}",
    "format-icons": {
      "urgent": "ïپھ",
      "active": "ï†’",
      "default": "ï„‘"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}  {text}",
    "format-icons": {
      "notification": "َ°‚ڑ",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚›",
      "dnd-none": "َ°‚›"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "wireplumber": {
    "on-click": "pwvucontrol",
    "on-click-right": "swayosd-client --output-volume mute-toggle",
    "on-scroll-down": "swayosd-client --output-volume -1",
    "on-scroll-up": "swayosd-client --output-volume +1",
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں 0%",
    "format-source": "ï„°",
    "format-source-muted": "ï„±",
    "format-icons": {
      "default": ["ï€¦", "ï€§", "ï€¨"]
    }
  },
  "cpu": {
    "format": "ï‹›  {usage}%",
    "tooltip": true,
    "interval": 1
  },
  "memory": {
    "format": "î؟…  {used} / {total} GiB",
    "tooltip": true,
    "interval": 1
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "ï‹‡ {temperatureC}",
    "format": "ï‹‰ {temperatureC}آ°C"
  },
  "network": {
    "format": "îھ، {bandwidthTotalBytes} îھڑ {bandwidthDownBytes}",
    "interval": 1
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
