{
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "warp-on-scroll": true,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{icon}",
    "format-icons": {
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}  {text}",
    "format-icons": {
      "notification": "≤░Γγ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γδ",
      "dnd-none": "≤░Γδ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
    "format-muted": "≤░ζθ 0%",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "pamixer --toggle-mute"
  },
  "cpu": {
    "format": "ΎΜδ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "Ό┐Ζ  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "ΎΜΘ {temperatureC}",
    "format": "ΎΜΚ {temperatureC}┬░C"
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ΎΩπ  {capacity}%",
    "format-plugged": "ΎΘο  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "on-click": "powerprofilesctl set performance && notify-send -u low \"Switch to $(powerprofilesctl get)\"",
    "on-click-right": "powerprofilesctl set power-saver && notify-send -u low \"Switch to $(powerprofilesctl get)\""
  },
  "clock": {
    "format": "ΎΒ│ {:%a %b %d %H:%M:%S}",
    "interval": 1
  }
}
