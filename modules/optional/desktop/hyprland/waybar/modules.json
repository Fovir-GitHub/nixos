{
  "custom/nixos": {
    "format": "´îô",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "hyprland/window": {
    "format": "{initialTitle}",
    "icon": true
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "warp-on-scroll": true,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{icon}",
    "format-icons": {
      "urgent": "´ü¬",
      "active": "´åÆ",
      "default": "´äæ"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon}  {text}",
    "format-icons": {
      "notification": "¾░éÜ",
      "none": "¾░é£",
      "dnd-notification": "¾░éø",
      "dnd-none": "¾░éø"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "wireplumber": {
    "on-click": "pwvucontrol",
    "on-click-right": "swayosd-client --output-volume mute-toggle",
    "on-scroll-down": "swayosd-client --output-volume -1",
    "on-scroll-up": "swayosd-client --output-volume +1",
    "format": "{icon} {volume}%",
    "format-muted": "¾░Øş",
    "format-source": "´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },
  "cpu": {
    "format": "´ïø  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "¯┐à  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "critical-threshold": 100,
    "format-critical": "´ïç {temperatureC}",
    "format": "´ïë {temperatureC}┬░C"
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["¾░âŞ", "¾░âş", "¾░âá"],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "´ùğ  {capacity}%",
    "format-plugged": "´çĞ  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "on-click": "powerprofilesctl set performance && notify-send -u low \"Switch to $(powerprofilesctl get)\"",
    "on-click-right": "powerprofilesctl set power-saver && notify-send -u low \"Switch to $(powerprofilesctl get)\""
  },
  "clock": {
    "format": "´ü│ {:%a %b %d %H:%M:%S}",
    "interval": 1
  }
}
